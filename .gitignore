# Whitelist repository contents by default.
# New files/directories are ignored unless explicitly allowed below.
/*

# Keep the ignore file itself tracked.
!/.gitignore

# Root files that belong in the repository.
!/Cargo.toml
!/Cargo.lock
!/LICENSE
!/README.md
!/README.zh-CN.md

# Tracked support/config directories.
!/.cargo/
!/.cargo/**
!/.github/
!/.github/workflows/
!/.github/workflows/ci.yml
!/.github/workflows/release.yml

# Source tree.
!/crates/
!/crates/**
